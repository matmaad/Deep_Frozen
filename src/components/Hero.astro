---
// Hero section with video background
---

<header
  id="inicio"
  class="relative min-h-screen flex items-center justify-center pt-14 overflow-hidden bg-deep-navy"
>
  <!-- Fallback Image (behind video) -->
  <img
    src="/images/PROCESS_MIX.webp"
    srcset="/images/PROCESS_MIX-400.webp 400w, /images/PROCESS_MIX.webp 1280w"
    sizes="100vw"
    alt="Deep Frozen — ultracongelados gourmet sellados al vacío"
    width="1280"
    height="720"
    class="absolute inset-0 w-full h-full object-cover z-[-1]"
  />

  <!-- Background Video (decorative, no audio) -->
  <video
    autoplay
    muted
    loop
    playsinline
    role="presentation"
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover z-0"
  >
    <source src="/videos/Steak_vacuum_sealed.mp4" type="video/mp4" />
  </video>

  <!-- Dark Overlay -->
  <div class="hero-video-overlay"></div>

  <!-- Gradient Accents -->
  <div
    class="absolute inset-0 opacity-20 z-0"
    style="background-image: radial-gradient(circle at top left, #00BCD4 0%, transparent 50%), radial-gradient(circle at bottom right, #C77B3F 0%, transparent 50%);"
  ></div>

  <!-- Content -->
  <div class="relative z-10 px-5 md:px-16 max-w-[1280px] mx-auto flex flex-col items-center text-center w-full">
    <div class="mb-8 flex justify-center">
      <h1 class="text-4xl md:text-5xl leading-none">
        <span class="logo-text">DEEP FROZEN</span>
      </h1>
    </div>
    <p class="font-body-lg text-body-lg text-pale-blue mb-8 max-w-xl">
      Ultracongelado + Sellado al Vacío. No es congelado común.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
      <a
        href="#productos"
        class="bg-warm-copper text-deep-navy font-body-md px-8 py-3 rounded gourmet-btn inline-flex items-center justify-center"
      >
        Ver Productos
      </a>
      <a
        href="#proceso"
        class="border-2 border-ice-cyan text-ice-cyan font-body-md px-8 py-3 rounded tech-btn inline-flex items-center justify-center bg-deep-navy/50"
      >
        Conoce el Proceso
      </a>
    </div>
  </div>
</header>