---
// Hero section with static background image
---

<header
  id="inicio"
  class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-deep-navy"
>
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/PROCESS_MIX.png"
      alt="Proceso Deep Frozen"
      class="w-full h-full object-cover"
    />
  </div>

  <!-- Dark Overlay -->
  <div class="hero-video-overlay"></div>

  <!-- Gradient Accents -->
  <div
    class="absolute inset-0 opacity-20 z-0"
    style="background-image: radial-gradient(circle at top left, #00BCD4 0%, transparent 50%), radial-gradient(circle at bottom right, #C77B3F 0%, transparent 50%);"
  ></div>

  <!-- Content -->
  <div class="relative z-10 px-5 md:px-16 max-w-[1280px] mx-auto flex flex-col items-center text-center w-full">
    <div class="mb-8 flex justify-center">
      <img
        src="/images/LOGO.png"
        alt="Deep Frozen Logo"
        class="w-1/4 max-w-[200px] min-w-[120px] h-auto object-contain"
      />
    </div>
    <h1 class="font-display-lg text-headline-lg-mobile md:text-display-lg text-frost-white mb-4 leading-tight">
      Frescura Gourmet en Casa
    </h1>
    <p class="font-body-lg text-body-lg text-pale-blue mb-8 max-w-xl">
      Ultracongelado + Sellado al Vacío. No es congelado común.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
      <a
        href="#productos"
        class="bg-warm-copper text-frost-white font-body-md px-8 py-3 rounded gourmet-btn text-center"
      >
        Ver Productos
      </a>
      <a
        href="#proceso"
        class="border-2 border-ice-cyan text-ice-cyan font-body-md px-8 py-3 rounded tech-btn text-center bg-deep-navy/50"
      >
        Conoce el Proceso
      </a>
    </div>
  </div>
</header>