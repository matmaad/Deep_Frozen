---
// Contact section — FAQ + Form + Contact Info (3 columns)
---

<section
  id="contacto"
  class="min-h-[calc(100vh-56px)] py-8 flex flex-col justify-center bg-gradient-to-t from-surface-container to-deep-navy text-on-surface px-5 md:px-16"
>
  <div class="max-w-[1280px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">

      <!-- Column 1: FAQ -->
      <div class="glass-frost p-5 rounded-xl border border-ice-cyan/20 bg-surface-container-lowest h-full">
        <h3 class="font-headline-sm text-headline-sm text-ice-cyan mb-4">Preguntas Frecuentes</h3>

        <div class="flex flex-col gap-3">
          <div>
            <h4 class="font-body-sm text-frost-white font-semibold mb-1">¿Hacen envíos a otras regiones?</h4>
            <p class="text-[14px] text-pale-blue/80 font-light leading-relaxed">
              Sí, realizamos envíos a todo Chile. Contacta por WhatsApp para coordinar despacho a tu región.
            </p>
          </div>

          <div>
            <h4 class="font-body-sm text-frost-white font-semibold mb-1">¿Cuánto duran congelados?</h4>
            <p class="text-[14px] text-pale-blue/80 font-light leading-relaxed">
              Hasta 12 meses congelados, gracias al sellado al vacío que bloquea el oxígeno.
            </p>
          </div>

          <div>
            <h4 class="font-body-sm text-frost-white font-semibold mb-1">¿Cómo se preparan?</h4>
            <p class="text-[14px] text-pale-blue/80 font-light leading-relaxed">
              Directo del freezer al horno o sartén, sin descongelar. En 10-15 minutos tienes un plato con calidad de restaurante.
            </p>
          </div>

          <div>
            <h4 class="font-body-sm text-frost-white font-semibold mb-1">¿Qué valor tienen?</h4>
            <p class="text-[14px] text-pale-blue/80 font-light leading-relaxed">
              Consulta precios por WhatsApp o en el formulario. Ofrecemos descuentos para pedidos al por mayor.
            </p>
          </div>
        </div>
      </div>

      <!-- Column 2: Form -->
      <div class="glass-frost p-5 rounded-xl border border-ice-cyan/20 bg-surface-container-lowest h-full">
        <h3 class="font-headline-sm text-headline-sm text-ice-cyan mb-3">Haz tu Pedido</h3>
        <form
          action="https://formspree.io/f/mzdlnbaj"
          method="POST"
          class="flex flex-col gap-3"
        >
          <div>
            <label class="block font-body-sm text-pale-blue mb-1" for="nombre">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Tu nombre"
              required
              class="w-full bg-deep-navy border border-ice-cyan/30 text-frost-white rounded px-4 py-2 focus:outline-none focus:border-ice-cyan focus:ring-1 focus:ring-ice-cyan transition-colors"
            />
          </div>
          <div>
            <label class="block font-body-sm text-pale-blue mb-1" for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@email.com"
              required
              class="w-full bg-deep-navy border border-ice-cyan/30 text-frost-white rounded px-4 py-2 focus:outline-none focus:border-ice-cyan focus:ring-1 focus:ring-ice-cyan transition-colors"
            />
          </div>
          <div>
            <label class="block font-body-sm text-pale-blue mb-1" for="asunto">Asunto</label>
            <input
              type="text"
              id="asunto"
              name="asunto"
              placeholder="¿Qué estás buscando?"
              required
              class="w-full bg-deep-navy border border-ice-cyan/30 text-frost-white rounded px-4 py-2 focus:outline-none focus:border-ice-cyan focus:ring-1 focus:ring-ice-cyan transition-colors"
            />
          </div>
          <div>
            <label class="block font-body-sm text-pale-blue mb-1" for="mensaje">Mensaje</label>
            <textarea
              id="mensaje"
              name="mensaje"
              placeholder="¿Qué productos te interesan?"
              rows="3"
              required
              class="w-full bg-deep-navy border border-ice-cyan/30 text-frost-white rounded px-4 py-2 focus:outline-none focus:border-ice-cyan focus:ring-1 focus:ring-ice-cyan transition-colors"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-warm-copper text-deep-navy font-body-md py-2 rounded gourmet-btn mt-1"
          >
            Enviar Mensaje
          </button>
        </form>
      </div>

      <!-- Column 3: Contact Info -->
      <div class="glass-frost p-5 rounded-xl border border-ice-cyan/20 bg-surface-container-lowest h-full">
        <h3 class="font-headline-sm text-headline-sm text-ice-cyan mb-4">Contacto Directo</h3>

        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4 text-pale-blue">
            <span class="material-symbols-outlined text-warm-copper">location_on</span>
            <p class="font-body-md">Av. Isidoro del Solar 210, Talca</p>
          </div>

          <div class="flex items-center gap-4 text-pale-blue">
            <span class="material-symbols-outlined text-warm-copper">call</span>
            <p class="font-body-md">+56 9 7878 7240</p>
          </div>

          <a
            href="https://wa.me/56978787240?text=Hola%2C%20me%20interesa%20conocer%20sus%20productos"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 text-pale-blue hover:text-ice-cyan transition-colors group"
          >
            <span class="material-symbols-outlined text-warm-copper group-hover:text-ice-cyan transition-colors">chat</span>
            <p class="font-body-md">WhatsApp</p>
          </a>

          <a
            href="https://instagram.com/deepfrozen_cl"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 text-pale-blue hover:text-ice-cyan transition-colors group"
          >
            <span class="material-symbols-outlined text-warm-copper group-hover:text-ice-cyan transition-colors">photo_camera</span>
            <p class="font-body-md">@deepfrozen_cl</p>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
