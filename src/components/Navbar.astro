---
// Navbar component
---

<nav
  id="navbar"
  class="fixed top-0 w-full z-50 bg-surface/80 border-b border-ice-cyan/20 shadow-sm md:backdrop-blur-md"
>
  <div class="flex justify-between items-center px-5 md:px-16 h-14 max-w-[1280px] mx-auto">
    <!-- Logo -->
    <a href="#inicio" class="text-lg leading-none">
      <span class="logo-text">DEEPFROZEN</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex gap-6 items-center font-body-sm text-body-sm">
      <a
        href="/#inicio"
        data-nav
        class="nav-link text-on-surface-variant hover:text-ice-cyan transition-colors hover:scale-105 duration-200"
      >
        Inicio
      </a>
      <a
        href="/#beneficios"
        data-nav
        class="nav-link text-on-surface-variant hover:text-ice-cyan transition-colors hover:scale-105 duration-200"
      >
        Beneficios
      </a>
      <a
        href="/menu"
        class="nav-link text-on-surface-variant hover:text-ice-cyan transition-colors hover:scale-105 duration-200"
      >
        Menú
      </a>
      <a
        href="/#proceso"
        data-nav
        class="nav-link text-on-surface-variant hover:text-ice-cyan transition-colors hover:scale-105 duration-200"
      >
        Proceso
      </a>
      <a
        href="/#mision"
        data-nav
        class="nav-link text-on-surface-variant hover:text-ice-cyan transition-colors hover:scale-105 duration-200"
      >
        Misión
      </a>
      <a
        href="/#testimonios"
        data-nav
        class="nav-link text-on-surface-variant hover:text-ice-cyan transition-colors hover:scale-105 duration-200"
      >
        Testimonios
      </a>
      <a
        href="/#contacto"
        class="bg-warm-copper text-deep-navy font-body-sm px-4 py-1.5 rounded gourmet-btn"
      >
        Contacto
      </a>

      <!-- Cart icon -->
      <button
        id="cart-icon-btn"
        class="relative text-on-surface-variant hover:text-ice-cyan transition-colors ml-2"
        aria-label="Abrir carrito"
      >
        <span class="material-symbols-outlined text-xl">shopping_cart</span>
        <span
          id="cart-badge"
          class="absolute -top-1.5 -right-1.5 bg-warm-copper text-deep-navy text-xs font-bold w-4 h-4 rounded-full flex items-center justify-center hidden"
        >0</span>
      </button>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-ice-cyan"
      aria-label="Abrir menú"
    >
      <span class="material-symbols-outlined text-3xl">menu</span>
    </button>
  </div>

  <!-- Mobile Menu (dropdown below navbar) -->
  <div
    id="mobile-menu"
    class="mobile-nav fixed top-14 left-0 w-full bg-surface/95 backdrop-blur-md border-b border-ice-cyan/20 z-50 flex flex-col md:hidden"
  >
    <div class="flex flex-col px-5 py-4 gap-1">
      <a href="/#inicio" class="mobile-link text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors" data-mobile-link>Inicio</a>
      <a href="/#beneficios" class="mobile-link text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors" data-mobile-link>Beneficios</a>
      <a href="/menu" class="mobile-link text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors" data-mobile-link>Menú</a>
      <a href="/#proceso" class="mobile-link text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors" data-mobile-link>Proceso</a>
      <a href="/#mision" class="mobile-link text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors" data-mobile-link>Misión</a>
      <a href="/#testimonios" class="mobile-link text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors" data-mobile-link>Testimonios</a>
      <a
        href="/#contacto"
        class="bg-warm-copper text-deep-navy font-body-md py-2.5 rounded gourmet-btn text-center mt-2 tracking-wide uppercase"
        data-mobile-link
      >
        Contacto
      </a>
      <!-- Mobile cart button -->
      <button
        id="mobile-cart-btn"
        class="flex items-center justify-center gap-2 text-frost-white text-base font-body-md py-2.5 hover:text-ice-cyan transition-colors mt-1"
      >
        <span class="material-symbols-outlined text-xl">shopping_cart</span>
        Carrito
      </button>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = mobileMenu?.querySelectorAll('[data-mobile-link]');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
    const icon = menuBtn.querySelector('.material-symbols-outlined');
    if (mobileMenu?.classList.contains('open')) {
      if (icon) icon.textContent = 'close';
      menuBtn.setAttribute('aria-label', 'Cerrar menú');
    } else {
      if (icon) icon.textContent = 'menu';
      menuBtn.setAttribute('aria-label', 'Abrir menú');
    }
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
    });
  });

  // Mobile cart button
  document.getElementById('mobile-cart-btn')?.addEventListener('click', () => {
    mobileMenu?.classList.remove('open');
    document.getElementById('cart-icon-btn')?.click();
  });

  // Active link highlighting via IntersectionObserver (no forced reflow)
  const sections = document.querySelectorAll('section[id], header[id]');
  const navLinks = document.querySelectorAll('.nav-link[data-nav]');
  let currentId = '';

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          currentId = entry.target.getAttribute('id') || '';
        }
      });
      navLinks.forEach((link) => {
        const href = link.getAttribute('href')?.replace('/#', '').replace('#', '') || '';
        if (href === currentId) {
          link.classList.add('text-warm-copper', 'font-bold', 'border-b-2', 'border-warm-copper', 'pb-1');
          link.classList.remove('text-on-surface-variant');
        } else {
          link.classList.remove('text-warm-copper', 'font-bold', 'border-b-2', 'border-warm-copper', 'pb-1');
          link.classList.add('text-on-surface-variant');
        }
      });
    },
    { rootMargin: '-20% 0px -60% 0px' }
  );

  sections.forEach((section) => observer.observe(section));
</script>