---
// Product catalog — 3 product cards
---

<section id="productos" class="min-h-[calc(100vh-56px)] py-12 flex flex-col justify-center bg-deep-navy px-5 md:px-16">
  <div class="max-w-[1280px] mx-auto">
    <h2 class="font-headline-lg text-headline-lg text-frost-white text-center mb-4">
      Catálogo Gourmet
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Pizza de Masa Madre -->
      <div class="product-card group relative bg-transparent rounded-xl overflow-hidden">
        <div class="product-card-inner glass-frost absolute inset-0 rounded-xl z-0"></div>
        <div class="relative z-10 p-3 h-full flex flex-col">
          <div class="overflow-hidden rounded-lg mb-2 aspect-[16/10] bg-surface-dim">
            <img
              src="/images/PIZZA.png"
              alt="Pizza de Masa Madre"
              class="w-full h-full object-cover product-img"
              loading="lazy"
            />
          </div>
          <div class="flex-grow">
            <span class="inline-block bg-ice-cyan/10 text-ice-cyan font-label-caps text-label-caps px-3 py-1 rounded-full mb-1 uppercase">
              Ultracongelado + Vacío
            </span>
            <h3 class="font-headline-sm text-headline-sm text-frost-white mb-1">Pizza de Masa Madre</h3>
            <p class="font-body-sm text-body-sm text-pale-blue mb-2">
              Fermentación lenta, ingredientes premium. Lista en 10 minutos al horno.
            </p>
          </div>
          <a href="#contacto" class="w-full bg-warm-copper text-deep-navy font-body-sm py-2 rounded gourmet-btn mt-auto text-center block">
            Consultar
          </a>
        </div>
      </div>

      <!-- Cinnamon Rolls -->
      <div class="product-card group relative bg-transparent rounded-xl overflow-hidden">
        <div class="product-card-inner glass-frost absolute inset-0 rounded-xl z-0"></div>
        <div class="relative z-10 p-3 h-full flex flex-col">
          <div class="overflow-hidden rounded-lg mb-2 aspect-[16/10] bg-surface-dim">
            <img
              src="/images/Cinnamon.png"
              alt="Cinnamon Rolls"
              class="w-full h-full object-cover product-img"
              loading="lazy"
            />
          </div>
          <div class="flex-grow">
            <span class="inline-block bg-ice-cyan/10 text-ice-cyan font-label-caps text-label-caps px-3 py-1 rounded-full mb-1 uppercase">
              Ultracongelado + Vacío
            </span>
            <h3 class="font-headline-sm text-headline-sm text-frost-white mb-1">Cinnamon Rolls</h3>
            <p class="font-body-sm text-body-sm text-pale-blue mb-2">
              Esponjosos y llenos de sabor. Hornea directamente desde congelado para un desayuno perfecto.
            </p>
          </div>
          <a href="#contacto" class="w-full bg-warm-copper text-deep-navy font-body-sm py-2 rounded gourmet-btn mt-auto text-center block">
            Consultar
          </a>
        </div>
      </div>

      <!-- Burgers Premium -->
      <div class="product-card group relative bg-transparent rounded-xl overflow-hidden">
        <div class="product-card-inner glass-frost absolute inset-0 rounded-xl z-0"></div>
        <div class="relative z-10 p-3 h-full flex flex-col">
          <div class="overflow-hidden rounded-lg mb-2 aspect-[16/10] bg-surface-dim">
            <img
              src="/images/Burger.png"
              alt="Burgers Premium"
              class="w-full h-full object-cover product-img"
              loading="lazy"
            />
          </div>
          <div class="flex-grow">
            <span class="inline-block bg-ice-cyan/10 text-ice-cyan font-label-caps text-label-caps px-3 py-1 rounded-full mb-1 uppercase">
              Ultracongelado + Vacío
            </span>
            <h3 class="font-headline-sm text-headline-sm text-frost-white mb-1">Burgers Premium</h3>
            <p class="font-body-sm text-body-sm text-pale-blue mb-2">
              Mezcla exclusiva de cortes, jugosas y listas para la parrilla sin descongelar.
            </p>
          </div>
          <a href="#contacto" class="w-full bg-warm-copper text-deep-navy font-body-sm py-2 rounded gourmet-btn mt-auto text-center block">
            Consultar
          </a>
        </div>
      </div>
    </div>
  </div>
</section>